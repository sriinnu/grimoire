{
  "name": "grimoire",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "version": "0.1.441",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "node scripts/dev-https.mjs",
    "build": "pnpm --filter @grimoire/markdown-editor build && tsc -b && vite build && node scripts/report-build-budget.mjs",
    "build:markdown-editor": "pnpm --filter @grimoire/markdown-editor build",
    "build:markdown-editor-baseline": "pnpm --filter @grimoire/markdown-editor-baseline build",
    "dev:markdown-editor-baseline": "pnpm --filter @grimoire/markdown-editor-baseline dev",
    "bundle-mcp": "node scripts/bundle-mcp-server.mjs",
    "bundle-starter-vault": "node scripts/bundle-starter-vault.mjs",
    "macos:build-app": "node scripts/build-macos-local-app.mjs",
    "macos:install-app": "node scripts/install-macos-app.mjs",
    "macos:install-built-app": "node scripts/install-macos-app.mjs --skip-build",
    "macos:test-build": "node scripts/install-macos-app.mjs",
    "doctor:source": "node scripts/doctor-public-source.mjs",
    "version:build": "node scripts/bump-build-version.mjs",
    "version:minor": "node scripts/bump-build-version.mjs --minor",
    "version:major": "node scripts/bump-build-version.mjs --major",
    "release:clean-artifacts": "node scripts/clean-tauri-bundles.mjs",
    "clean:debug": "node scripts/clean-tauri-debug-target.mjs",
    "clean:debug:dry": "node scripts/clean-tauri-debug-target.mjs --dry-run",
    "release:source-notes": "node scripts/build-source-release-notes.mjs --output .release/source-release-notes.md",
    "release:preflight": "node scripts/release-preflight.mjs",
    "release:secrets": "node scripts/release-secret-handoff.mjs",
    "release:verify-artifacts": "node scripts/verify-release-artifacts.mjs",
    "audit:local-only": "node scripts/audit-local-only.mjs",
    "audit:secrets": "node scripts/scan-secrets.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:https": "tauri dev --config '{\"build\":{\"devUrl\":\"https://localhost:5202\",\"beforeDevCommand\":\"pnpm dev:https\"}}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:markdown-editor": "pnpm test:markdown-editor:js && pnpm test:markdown-editor:swift",
    "test:markdown-editor:js": "pnpm --filter @grimoire/markdown-editor build && pnpm exec vitest run src/utils/markdownParity.test.ts markdown-editor/packages/js/src/react/grimoireSlashCommandItems.test.tsx",
    "test:markdown-editor:swift": "swift test --disable-sandbox --package-path markdown-editor/packages/swift",
    "test:local-only-audit": "node scripts/audit-local-only.mjs --self-test",
    "test:secret-scan": "node scripts/scan-secrets.mjs --self-test",
    "test:macos-install-app": "node scripts/verify-app-bundle-version.mjs --self-test && node scripts/install-macos-app.mjs --self-test",
    "test:doctor-source": "node scripts/doctor-public-source.mjs --self-test",
    "test:release-secrets": "node scripts/release-secret-handoff.mjs --self-test",
    "test:source-release-notes": "node scripts/build-source-release-notes.mjs --self-test",
    "test:rust-platform-guards": "node scripts/verify-rust-platform-guards.mjs",
    "test:rust-platform-guards:self": "node scripts/verify-rust-platform-guards.mjs --self-test",
    "test:native-tauri-link": "cargo build --manifest-path=src-tauri/Cargo.toml --no-default-features --locked",
    "test:native-tauri-startup": "node scripts/run-native-startup-smoke.mjs",
    "test:object-storage-live": "node scripts/run-object-storage-live-proof.mjs --require-enabled",
    "test:release-preflight": "node scripts/release-preflight.mjs --self-test",
    "test:release-artifacts": "node scripts/verify-release-artifacts.mjs --self-test",
    "test:github-actions-runtime": "node scripts/verify-github-actions-runtime.mjs",
    "test:release-pages": "node scripts/build-release-pages.mjs --self-test",
    "test:public-doc-links": "node scripts/verify-public-doc-links.mjs",
    "test:public-doc-links:self": "node scripts/verify-public-doc-links.mjs --self-test",
    "test:starter-vault": "node scripts/verify-starter-vault-showcase.mjs",
    "test:e2e": "playwright test",
    "playwright:smoke": "playwright test --config playwright.smoke.config.ts tests/smoke/example.spec.ts tests/smoke/vault-switcher-bottom-bar.spec.ts tests/smoke/wikilink-path-fix.spec.ts",
    "playwright:regression": "playwright test tests/smoke/",
    "playwright:integration": "playwright test --config playwright.integration.config.ts",
    "test:coverage": "node scripts/run-vitest-coverage.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@blocknote/code-block": "^0.46.2",
    "@blocknote/core": "^0.46.2",
    "@blocknote/mantine": "^0.46.2",
    "@blocknote/react": "^0.46.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@grimoire/markdown-editor": "workspace:*",
    "@lezer/highlight": "^1.2.3",
    "@mantine/core": "^8.3.18",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^10.55.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "katex": "^0.16.47",
    "lucide-react": "^0.564.0",
    "mermaid": "^11.15.0",
    "posthog-js": "^1.376.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.7",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "unicode-emoji-json": "^0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vitest": "^4.1.7",
    "ws": "^8.21.0"
  },
  "workspaces": [
    "mcp-server",
    "markdown-editor/packages/js",
    "markdown-editor/apps/baseline-web"
  ],
  "patchedDependencies": {
    "@blocknote/core@0.46.2": "patches/@blocknote__core@0.46.2.patch",
    "@blocknote/react@0.46.2": "patches/@blocknote__react@0.46.2.patch",
    "@tiptap/extension-link@3.19.0": "patches/@tiptap__extension-link@3.19.0.patch",
    "prosemirror-tables@1.8.5": "patches/prosemirror-tables@1.8.5.patch"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": ">=7.29.6",
      "@hono/node-server": ">=1.19.13",
      "@opentelemetry/core": ">=2.8.0",
      "dompurify": ">=3.4.9",
      "esbuild": ">=0.28.1",
      "express-rate-limit": ">=8.2.2",
      "fast-uri": ">=3.1.2",
      "hono": ">=4.12.25",
      "ip-address": ">=10.1.1",
      "js-yaml": ">=4.2.0",
      "markdown-it": ">=14.2.0",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "postcss": ">=8.5.10",
      "protobufjs": ">=7.6.3",
      "qs": ">=6.15.2",
      "rollup": ">=4.59.0",
      "uuid": ">=11.1.1",
      "vite": ">=7.3.5 <8",
      "ws": ">=8.21.0"
    }
  }
}
