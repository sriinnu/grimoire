          "fill": "$--muted",
          "stroke": {
            "align": "inside",
            "thickness": {
              "top": 1
            },
            "fill": "$--border"
          },
          "gap": 16,
          "padding": [8, 16],
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "srs_hint1",
              "fill": "$--muted-foreground",
