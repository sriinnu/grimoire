          "layout": "vertical",
          "gap": 4,
          "padding": [10, 16],
          "stroke": {
            "align": "inside",
            "thickness": {
              "bottom": 1
            },
            "fill": "$--border"
          },
          "children": [
            {
              "type": "text",
              "id": "srs_s4_label",
              "fill": "$--accent-blue",
