              "type": "frame",
              "id": "srs_r3_meta",
              "name": "metadataRow",
              "width": "fill_container",
              "gap": 4,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "srs_r3_date",
