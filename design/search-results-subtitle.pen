                  "fontFamily": "Inter",
                  "fontSize": 11
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "srs_result3",
          "name": "searchResult3",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 4,
          "padding": [10, 16, 14, 16],
          "children": [
            {
              "type": "frame",
              "id": "srs_r3_titleRow",
              "name": "titleRow",
              "width": "fill_container",
