                  "fontSize": 11
                },
                {
                  "type": "text",
                  "id": "srs_r2_created",
                  "fill": "$--muted-foreground",
                  "content": "Created Jan 15",
                  "fontFamily": "Inter",
                  "fontSize": 11
                },
                {
                  "type": "text",
                  "id": "srs_r2_sep2",
                  "fill": "$--muted-foreground",
                  "content": "\u00b7",
                  "fontFamily": "Inter",
                  "fontSize": 11
                },
                {
                  "type": "text",
                  "id": "srs_r2_words",
