          "cornerRadius": [12, 12, 12, 12],
          "layout": "vertical",
          "alignItems": "center",
          "gap": 24,
          "padding": [48, 48, 48, 48],
          "stroke": "#E9E9E7",
          "strokeThickness": 1,
          "children": [
            {
              "type": "frame",
              "id": "missing_icon_wrap",
              "name": "Warning Icon",
              "width": 64,
              "height": 64,
              "fill": "#FFF3E0",
              "cornerRadius": [16, 16, 16, 16],
              "layout": "vertical",
              "alignItems": "center",
              "justifyContent": "center",
              "children": [
                {
                  "type": "text",
                  "id": "missing_icon_text",
                  "content": "⚠",
                  "fontSize": 28,
                  "fill": "#E8890C",
                  "fontFamily": "Inter"
