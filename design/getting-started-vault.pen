              "fill": "#F7F6F3",
              "cornerRadius": [6, 6, 6, 6],
              "layout": "horizontal",
              "alignItems": "center",
              "justifyContent": "center",
              "padding": [8, 12, 8, 12],
              "children": [
                {
                  "type": "text",
                  "id": "missing_path_text",
                  "content": "~/Grimoire",
                  "fill": "#787774",
                  "fontFamily": "SF Mono, monospace",
                  "fontSize": 12
                }
              ]
            },
            {
              "type": "rectangle",
              "id": "missing_divider",
              "width": "fill_container",
              "height": 1,
              "fill": "#E9E9E7"
            },
            {
              "type": "frame",
              "id": "missing_actions",
              "name": "Actions",
              "layout": "vertical",
              "gap": 12,
              "width": "fill_container",
              "children": [
                {
                  "type": "frame",
                  "id": "btn_recreate_vault",
                  "name": "Create Getting Started Vault Button",
                  "width": "fill_container",
                  "height": 44,
                  "fill": "#2383E2",
                  "cornerRadius": [8, 8, 8, 8],
                  "layout": "horizontal",
                  "alignItems": "center",
                  "justifyContent": "center",
                  "gap": 8,
                  "children": [
                    {
                      "type": "text",
                      "id": "btn_recreate_icon",
                      "content": "＋",
                      "fill": "#FFFFFF",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "btn_recreate_label",
                      "content": "Create Getting Started vault",
                      "fill": "#FFFFFF",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "600"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "btn_choose_folder",
                  "name": "Choose Different Folder Button",
                  "width": "fill_container",
                  "height": 44,
                  "fill": "#FFFFFF",
                  "stroke": "#E9E9E7",
                  "strokeThickness": 1,
                  "cornerRadius": [8, 8, 8, 8],
                  "layout": "horizontal",
                  "alignItems": "center",
                  "justifyContent": "center",
                  "gap": 8,
                  "children": [
                    {
                      "type": "text",
                      "id": "btn_choose_icon",
                      "content": "📂",
                      "fill": "#37352F",
                      "fontFamily": "Inter",
                      "fontSize": 14
                    },
                    {
                      "type": "text",
                      "id": "btn_choose_label",
                      "content": "Choose a different folder",
                      "fill": "#37352F",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "500"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
