{
  "name": "Grimoire Getting Started showcase mirror",
  "purpose": "Curated local mirror of the public Getting Started starter vault plus a QA fixture for browser and native review.",
  "public_starter_repo": {
    "url": "https://github.com/sriinnu/grimoire-getting-started.git",
    "extra_public_files": [
      "README.md",
      "LICENSE"
    ],
    "app_repaired_files": [
      "AGENTS.md",
      "type.md",
      "note.md"
    ]
  },
  "showcase": {
    "launch_day": "2026-05-31",
    "feature_tour": "grimoire-feature-tour.md",
    "start_note": "grimoire-start-here.md",
    "required_surfaces": [
      "Dashboard and Daily Flow",
      "Quick Capture",
      "Markdown editor",
      "Properties and types",
      "Search and commands",
      "Wikilinks, backlinks, graph",
      "Journal lane",
      "Dream lane",
      "Calendar and Time Loom",
      "Canvas and attachments",
      "Audio transcription",
      "Console notes",
      "Agent Council",
      "Local agents",
      "Privacy and memory",
      "Portability and sync",
      "Settings and themes"
    ]
  },
  "large_fixture": {
    "generator": "python3 scripts/generate_demo_vault.py",
    "default_output": "generated-fixtures/demo-vault-large"
  },
  "scenarios": [
    {
      "id": "exact-match-search",
      "reason": "Quick Open should rank the exact title 'Writing' above prefix matches.",
      "files": [
        "topic-writing.md",
        "writing-for-clarity-vs-writing-for-credit.md",
        "writing-weekly-rhythm.md"
      ]
    },
    {
      "id": "relationship-rendering",
      "reason": "Relationship keys should render in the inspector instead of as plain properties.",
      "files": [
        "responsibility-sponsorships.md",
        "measure-sponsorship-mrr.md",
        "measure-close-rate.md",
        "procedure-quarterly-sponsor-outreach.md",
        "procedure-sponsor-onboarding.md",
        "24q4-grimoire-start.md",
        "24q4.md",
        "person-mira-sen.md"
      ]
    },
    {
      "id": "project-navigation",
      "reason": "Projects, quarters, and a saved view give keyboard QA a compact but representative browsing path.",
      "files": [
        "24q4.md",
        "25q1.md",
        "25q2.md",
        "24q4-grimoire-start.md",
        "25q1-grimoire-v1.md",
        "25q2-grimoire-v2.md",
        "views/active-projects.yml"
      ]
    },
    {
      "id": "sidebar-spotlight-project-text",
      "reason": "Sidebar Spotlight should find editable project text and docs, not only Markdown notes.",
      "files": [
        "grimoire-search-and-commands.md",
        "docs/sidebar-spotlight-proof.ts"
      ]
    },
    {
      "id": "attachment-rendering",
      "reason": "A note with a real binary attachment keeps image/block QA anchored to the fixture.",
      "files": [
        "grimoire-qa-reference.md",
        "attachments/grimoire-reference.png"
      ]
    }
  ]
}
