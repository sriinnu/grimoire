#!/bin/sh
# Pre-commit: fast local gate before commit.
set -e

ensure_node_tooling() {
  if command -v node >/dev/null 2>&1 && command -v pnpm >/dev/null 2>&1; then
    return 0
  fi
  NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    # shellcheck disable=SC1090
    . "$NVM_DIR/nvm.sh" --no-use
    nvm use --silent node >/dev/null 2>&1 || true
  fi
  if ! command -v node >/dev/null 2>&1 || ! command -v pnpm >/dev/null 2>&1; then
    echo "❌ node and pnpm must be available before committing."
    exit 1
  fi
}

require_workable_branch() {
  if ! git symbolic-ref -q HEAD >/dev/null 2>&1; then
    echo "❌ Detached HEAD commits are not allowed."
    exit 1
  fi
  CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
  case "$CURRENT_BRANCH" in
    main|feat/*|fix/*|chore/*|docs/*|refactor/*|style/*|test/*|build/*|ci/*|perf/*) ;;
    *)
      echo "❌ Branch '$CURRENT_BRANCH' does not match an allowed prefix."
      echo "   Use: main feat/* fix/* chore/* docs/* refactor/* style/* test/* build/* ci/* perf/*"
      exit 1
      ;;
  esac
}

require_workable_branch
ensure_node_tooling

# Shared secret scanner from domain-knowledge (matches other repos).
SECRET_SCANNER="${SECRET_SCANNER:-$HOME/Sriinnu/Personal/domain-knowledge/security/hooks/pre-commit-secrets.sh}"
if [ -f "$SECRET_SCANNER" ]; then
  bash "$SECRET_SCANNER" || exit 1
fi

echo "🔍 Pre-commit checks..."

# Local-only files are allowed to exist on disk, but never in commit-ready paths.
echo "  → local-only audit..."
pnpm audit:local-only

# Lint + types — only if TS files staged.
STAGED_TS=$(git diff --cached --name-only | grep -E '\.(ts|tsx)$' || true)
if [ -n "$STAGED_TS" ]; then
  echo "  → lint + tsc..."
  pnpm lint --quiet
  npx tsc --noEmit
fi

# Unit tests — fast, runs on every commit.
echo "  → tests..."
pnpm exec vitest run --silent

echo "✅ Pre-commit passed"
