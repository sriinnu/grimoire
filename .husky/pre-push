#!/bin/sh
# Pre-push: fast local gate before pushing.
#
# Direct pushes to main are refused — open a PR from a feature branch
# (feat/*, fix/*, chore/*, docs/*, refactor/*, style/*, test/*, build/*,
# ci/*, perf/*) and merge through GitHub.
#
# Heavy gates (coverage, Playwright, CodeScene) belong on GitHub Actions
# when CI workflows land. Local gate keeps PR iterations fast.
#
# DO NOT skip with --no-verify (admin-only emergency override).
set -e

ensure_node_tooling() {
  if command -v node >/dev/null 2>&1 && command -v pnpm >/dev/null 2>&1; then
    return 0
  fi
  NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    # shellcheck disable=SC1090
    . "$NVM_DIR/nvm.sh" --no-use
    nvm use --silent node >/dev/null 2>&1 || true
  fi
  if ! command -v node >/dev/null 2>&1 || ! command -v pnpm >/dev/null 2>&1; then
    echo "❌ node and pnpm must be available before pushing."
    exit 1
  fi
}

validate_push_branch() {
  if ! git symbolic-ref -q HEAD >/dev/null 2>&1; then
    echo "❌ Detached HEAD pushes are not allowed."
    exit 1
  fi

  while IFS=' ' read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    [ -z "$LOCAL_REF" ] && continue
    case "$LOCAL_REF:$REMOTE_REF" in
      "(delete)":refs/heads/*) ;;
      refs/heads/*:refs/heads/main)
        echo "❌ Direct pushes to main are not allowed."
        echo "   Open a PR instead:"
        echo "     git switch -c feat/your-change"
        echo "     git push -u origin HEAD"
        echo "     gh pr create"
        exit 1
        ;;
      refs/heads/feat/*:refs/heads/feat/*) ;;
      refs/heads/fix/*:refs/heads/fix/*) ;;
      refs/heads/chore/*:refs/heads/chore/*) ;;
      refs/heads/docs/*:refs/heads/docs/*) ;;
      refs/heads/refactor/*:refs/heads/refactor/*) ;;
      refs/heads/style/*:refs/heads/style/*) ;;
      refs/heads/test/*:refs/heads/test/*) ;;
      refs/heads/build/*:refs/heads/build/*) ;;
      refs/heads/ci/*:refs/heads/ci/*) ;;
      refs/heads/perf/*:refs/heads/perf/*) ;;
      refs/tags/*:refs/tags/*) ;;
      *)
        echo "❌ Unsupported ref: ${LOCAL_REF:-<none>} -> ${REMOTE_REF:-<none>}"
        echo "   Branch must match: feat/* fix/* chore/* docs/* refactor/* style/* test/* build/* ci/* perf/*"
        exit 1
        ;;
    esac
  done <<EOF
$PUSH_INPUT
EOF
}

if [ -t 0 ]; then PUSH_INPUT=""; else PUSH_INPUT=$(cat); fi
validate_push_branch
ensure_node_tooling

echo ""
echo "🚀 Pre-push gate"
echo "================"

# 0. Local-only audit — private docs/mockups/MCP wiring must not ship.
echo ""
echo "🔒 Local-only audit..."
pnpm audit:local-only
echo "  ✅ Local-only audit OK"

echo ""
echo "🪟 Rust platform guards..."
pnpm test:rust-platform-guards
echo "  ✅ Rust platform guards OK"

echo ""
echo "📣 Public readiness docs..."
pnpm test:public-readiness-docs
echo "  ✅ Public readiness docs OK"

echo ""
echo "🔗 Public doc links..."
pnpm test:public-doc-links
echo "  ✅ Public doc links OK"

echo ""
echo "🛰️  Release pages..."
pnpm test:release-pages
echo "  ✅ Release pages OK"

echo ""
echo "⚙️  GitHub Actions runtime..."
pnpm test:github-actions-runtime
echo "  ✅ GitHub Actions runtime OK"

echo ""
echo "🧭 Starter vault showcase..."
pnpm test:starter-vault
echo "  ✅ Starter vault showcase OK"

# 1. TypeScript + Vite build — catches compile errors fast
echo ""
echo "📦 Build..."
pnpm exec tsc --noEmit
pnpm build
echo "  ✅ Build OK"

# 2. Frontend unit tests (no coverage threshold — that's CI's job)
echo ""
echo "🧪 Frontend tests..."
pnpm test --silent
echo "  ✅ Tests OK"

# 3. Shared MarkdownEditor parity checks (skipped when editor semantics are untouched)
PUSH_TARGET=$(git rev-parse @{push} 2>/dev/null || echo "")
CHANGED=""
MARKDOWN_EDITOR_CHANGED=true
if [ -n "$PUSH_TARGET" ]; then
  CHANGED=$(git diff --name-only "$PUSH_TARGET"..HEAD)
  if ! echo "$CHANGED" | grep -qE '^(markdown-editor/packages/swift/|markdown-editor/packages/js/|src/components/(grimoireEditorFormattingConfig|tagCollectionSuggestions)(\.test)?\.tsx?|src/utils/(compact-markdown|mathMarkdown|markdownParity|markdownSemanticsAdapter|wikilinks)(\.test)?\.ts|src-tauri/tauri\.conf\.json|index\.html)'; then
    MARKDOWN_EDITOR_CHANGED=false
  fi
fi
if [ "$MARKDOWN_EDITOR_CHANGED" = true ]; then
  echo ""
  echo "📝 MarkdownEditor parity..."
  pnpm run test:markdown-editor
  echo "  ✅ MarkdownEditor parity OK"
else
  echo ""
  echo "⏭️  MarkdownEditor parity — skipped (no editor semantics changes)"
fi

# 4. Rust lint (skipped when src-tauri/ untouched)
echo ""
RUST_CHANGED=true
if [ -n "$PUSH_TARGET" ]; then
  if ! echo "$CHANGED" | grep -qE '^(src-tauri/|Cargo)'; then
    RUST_CHANGED=false
  fi
fi
if [ "$RUST_CHANGED" = true ]; then
  echo "🔧 Rust clippy + fmt..."
  cargo clippy --manifest-path=src-tauri/Cargo.toml -- -D warnings
  cargo fmt --manifest-path=src-tauri/Cargo.toml -- --check
  echo "  ✅ Rust lint OK"
else
  echo "⏭️  Rust lint — skipped (no src-tauri/ changes)"
fi

echo ""
echo "✅ Gate passed — pushing"
echo ""
