{
  "compactMarkdown": [
    {
      "name": "tight bullet list",
      "input": "* Item one\n\n* Item two\n\n* Item three\n",
      "output": "- Item one\n- Item two\n- Item three\n"
    },
    {
      "name": "preserve fenced code blanks",
      "input": "```\nline one\n\nline two\n\nline three\n```\n",
      "output": "```\nline one\n\nline two\n\nline three\n```\n"
    },
    {
      "name": "decode entities around strong text",
      "input": "**Remove&#x20;**`NoteWindow`**&#x20;and render the full&#x20;**`App`**&#x20;component.**\n",
      "output": "**Remove** `NoteWindow` **and render the full** `App` **component.**\n"
    }
  ],
  "wikilinkPreprocess": [
    {
      "name": "plain and aliased links",
      "input": "See [[My Note]] and [[path/note|Alias]].",
      "output": "See ‹WIKILINK:My Note› and ‹WIKILINK:path/note|Alias›."
    }
  ],
  "frontmatterSplits": [
    {
      "name": "frontmatter with blank body lead",
      "input": "---\ntitle: Hello\n---\n\n# Hello\n",
      "frontmatter": "---\ntitle: Hello\n---\n",
      "body": "\n# Hello\n"
    },
    {
      "name": "missing closing delimiter",
      "input": "---\ntitle: Hello\nNo closing",
      "frontmatter": "",
      "body": "---\ntitle: Hello\nNo closing"
    }
  ],
  "outgoingLinks": [
    {
      "name": "sorted unique targets",
      "input": "See [[B|Bee]], [[A]], [[B|Other]].",
      "output": ["A", "B"]
    }
  ],
  "snippets": [
    {
      "name": "strip heading and markdown",
      "input": "---\ntitle: Test\n---\n# Test\n\n- **Ship** the [editor](https://example.com) with [[Notes|links]].",
      "output": "Ship the editor with links."
    }
  ],
  "wordCounts": [
    {
      "name": "strip title formatting and wikilinks",
      "input": "# Title\n\nHello **bold** [[Hidden Link]] world.",
      "output": 3
    },
    {
      "name": "preserve punctuation residue after wikilink removal",
      "input": "# Title\n\nSee [[B]].",
      "output": 2
    }
  ],
  "mathPreprocess": [
    {
      "name": "inline math",
      "input": "Energy is $E=mc^2$.",
      "output": "Energy is @@GRIMOIRE_MATH_INLINE:E%3Dmc%5E2@@."
    },
    {
      "name": "single-line display math",
      "input": "Before\n$$x + y$$\nAfter",
      "output": "Before\n@@GRIMOIRE_MATH_BLOCK:x%20%2B%20y@@\nAfter"
    },
    {
      "name": "ignore fenced code",
      "input": "```\n$x$\n```\n$x$",
      "output": "```\n$x$\n```\n@@GRIMOIRE_MATH_INLINE:x@@"
    }
  ]
}
